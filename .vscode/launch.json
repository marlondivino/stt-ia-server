{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Nest.js",
      "program": "${workspaceFolder}/node_modules/@nestjs/cli/bin/nest.js",
      "args": ["start", "--debug", "--watch"],
      "protocol": "inspector",
      "console": "integratedTerminal",
      "restart": true,
      "sourceMaps": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Nest.js",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Nest.js",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:debug"],
      "autoAttachChildProcesses": true,
      "console": "integratedTerminal",
      "restart": true,
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Nest.js",
      "port": 9229,
      "restart": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}

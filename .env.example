# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Database (PostgreSQL) ────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/mydb

# ─── Authentication (JWT) ─────────────────────────────
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=24h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── Ollama (LLM Summarization) ──────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Whisper (STT Transcription) ─────────────────────
# Model sizes: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=base
# Device: "cuda" for NVIDIA GPU, "cpu" for CPU-only
WHISPER_DEVICE=cuda
# Compute type: "float16" for GPU, "int8" for CPU
WHISPER_COMPUTE_TYPE=float16
PYTHON_PATH=python

# ─── Upload ──────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Job Retention ───────────────────────────────────
# Number of days to keep completed jobs in PostgreSQL
JOB_RETENTION_DAYS=365
